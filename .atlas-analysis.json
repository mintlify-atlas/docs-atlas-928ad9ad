  "keyFeatures": [
    "0-RTT TCP and UDP proxying over QUIC",
    "Automatic TLS certificate provisioning via ACME (Let's Encrypt)",
    "Self-signed certificate support with hot-reload",
    "Flexible ACL (Access Control List) with configurable outbound rules",
    "RESTful API for traffic statistics and user management",
    "BBR3 congestion control algorithm support",
    "SOCKS5 outbound proxy support",
    "TCP/UDP port forwarding (client)",
    "Docker with multi-platform support (amd64, arm64)",
    "JEMalloc and AWS-LC-RS for improved performance"
  ],
  "publicApiSurface": [
    "tuic-server -c <config>",
    "tuic-server -d <config-dir>",
    "tuic-server --init",
    "tuic-client -c <config>",
    "GET /online",
    "GET /detailed_online",
    "POST /kick",
    "GET /traffic",
    "GET /reset_traffic"
  ]
